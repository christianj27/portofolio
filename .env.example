# Vercel Environment Variables — add these in Vercel Dashboard → Settings → Environment Variables

# Brevo API key (create in Brevo → Settings → API Keys)
# Starts with: xkeysib-
BREVO_API_KEY=your_brevo_api_key

# Email to receive contact form messages
CONTACT_EMAIL=christian@christianjeremia.com

# Email to send from (must be verified in Brevo)
SENDER_EMAIL=christian@christianjeremia.com
